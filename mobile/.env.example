# Mobile app environment variables. Copy to .env.local and fill in.
# Anything prefixed with EXPO_PUBLIC_ is bundled into the JS — do NOT put service-role keys here.

# Supabase project URL — e.g. https://abcdefghijklm.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon key — safe to ship in client (RLS enforces access).
# Found in: Supabase dashboard → Project Settings → API → "anon public" key.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Sentry DSN — leave empty in dev. Events are silenced until Phase 10.
EXPO_PUBLIC_SENTRY_DSN=

# Environment marker — "development" or "production"
EXPO_PUBLIC_ENV=development
