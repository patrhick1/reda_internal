# Supabase CLI credentials (this file is for repo-root scripts, NOT bundled into the app).
# Copy to .env and fill in. Never commit .env.

# Project ref from your Supabase dashboard URL:
# https://supabase.com/dashboard/project/<THIS_PART>
SUPABASE_PROJECT_REF=

# Database password — set in Supabase dashboard → Project Settings → Database → Connection string.
# Used by `supabase db pull` / `supabase db push`.
SUPABASE_DB_PASSWORD=

# Personal access token from https://supabase.com/dashboard/account/tokens
# Used by `supabase link` so you don't have to log in interactively each time.
SUPABASE_ACCESS_TOKEN=